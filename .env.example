# Copy to .env and fill in real values. Never commit the filled .env file.

# Model
MODEL_PATH=/app/models/nutrient_model_v2.pkl
MODEL_VERSION=v2

# External API timeouts
EXTERNAL_API_TIMEOUT=45

# Feature flags
ALLOW_DATASET_ENDPOINT=false

# Optional satellite API keys
AGROMONITOR_API_KEY=

# Google Earth Engine credentials path
GOOGLE_APPLICATION_CREDENTIALS=./soil-model-service-account.json
